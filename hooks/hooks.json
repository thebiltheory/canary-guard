{
  "description": "Output-integrity canary: SessionStart mints + injects the per-user token; Stop validates its presence in the last response.",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/ensure-canary.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/check-canary.sh\"",
            "statusMessage": "Checking output-integrity canary"
          }
        ]
      }
    ]
  }
}
