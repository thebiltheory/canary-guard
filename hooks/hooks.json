{
  "SessionStart": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/ensure-canary.sh\""
        }
      ]
    }
  ],
  "Stop": [
    {
      "hooks": [
        {
          "type": "command",
          "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/check-canary.sh\"",
          "statusMessage": "Checking output-integrity canary"
        }
      ]
    }
  ]
}
