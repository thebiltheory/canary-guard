{
  "description": "Output-integrity canary: SessionStart mints + injects the per-user token; UserPromptSubmit reinforces the rule each turn; Stop validates the start+end tokens and classifies any break (truncation vs not-engaged).",
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/ensure-canary.sh\""
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/reinforce-canary.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "\"${CLAUDE_PLUGIN_ROOT}/scripts/check-canary.sh\"",
            "statusMessage": "Checking output-integrity canary"
          }
        ]
      }
    ]
  }
}
